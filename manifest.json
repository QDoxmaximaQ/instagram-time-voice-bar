{
  "manifest_version": 3,
  "name": "Instagram Voice and Time Bar",
  "version": "1.0",
  "description": "Enhanced audio and duration controls for Instagram videos.",
  "icons": {
    "16": "images/icon.png",
    "48": "images/icon.png",
    "128": "images/icon.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.instagram.com/*"],
      "js": ["content.js"]
    }
  ]
}